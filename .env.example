# Server
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# Book price (KES) — must match frontend
BOOK_PRICE=499

# M-Pesa Daraja (Safaricom)
# Sandbox: https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
# Optional till/paybill label shown to customer
MPESA_ACCOUNT_REFERENCE=DrKimemia
MPESA_TRANSACTION_DESC=Book purchase

# Callback must be a public HTTPS URL in production (use ngrok for local tests)
# Example: https://your-domain.com/api/mpesa/callback
MPESA_CALLBACK_URL=

# Admin notifications (optional but recommended)
ADMIN_EMAIL=hello@drkimemia.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dr. Kimemia Books <hello@drkimemia.com>"

# When true (default if M-Pesa keys missing), STK is simulated for UI testing
MPESA_MOCK=auto
